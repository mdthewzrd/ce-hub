# CE-Hub Git Ignore Configuration

# Chat system logs and temporary files
chats/chat_system.log
chats/active/*temp*
chats/summaries/*temp*
chats/archive/.backup*
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
# Claude Code settings (keep main settings, ignore local)
.claude/settings.local.json
.claude/cache/
.claude/temp/

# Archon connection cache
.archon-cache/
.mcp-cache/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/
*.out

# Cache
*.cache
.cache/
.pytest_cache/

# Next.js build and cache (exclude entirely)
.next/
*.pack
*.pack.gz

# Model Cache (HuggingFace)
.cache/huggingface/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node modules (for any frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Large model files
*.bin
*.pt
*.pth
models/

# API keys and secrets
secrets.json
credentials.json
*_key.json

# Backup files
*.bak
*.backup

# Config files with secrets (examples should be kept)
config/secrets.*
config/production.*
!config/*.example.*

# Documentation build artifacts
docs/_build/
docs/site/

# Package files
*.tar.gz
*.zip
*.rar

# Git worktrees (Crystal)
/worktrees/
/worktree-*/

# Exclude unrelated projects
traderra/
