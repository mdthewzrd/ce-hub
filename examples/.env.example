# Supabase Authentication Configuration
# CE-Hub Agent Playground - Production Environment Template
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ==============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ==============================================================================

# Your Supabase project URL
# Find this in: Supabase Dashboard > Settings > API
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=your_supabase_project_url

# Your Supabase anonymous/public key
# Find this in: Supabase Dashboard > Settings > API > Project API keys > anon/public
# This key is safe to use in client-side code
SUPABASE_ANON_KEY=your_supabase_anon_key

# ==============================================================================
# REDIRECT URL SECURITY (REQUIRED FOR OAUTH)
# ==============================================================================

# Comma-separated list of allowed redirect URL hosts
# Supports wildcard patterns (*.example.com matches app.example.com, staging.example.com, etc.)
#
# SECURITY NOTE: This prevents open redirect vulnerabilities by validating
# redirect URLs against an allow-list before OAuth flow initiation
#
# Development example:
# ALLOWED_REDIRECT_HOSTS=localhost,127.0.0.1,*.localhost
#
# Production example:
# ALLOWED_REDIRECT_HOSTS=app.example.com,*.example.com,example.com
#
ALLOWED_REDIRECT_HOSTS=localhost,127.0.0.1

# ==============================================================================
# OAUTH SCOPE CONFIGURATION (OPTIONAL)
# ==============================================================================

# Provider-specific OAuth scopes
# If not specified, defaults to minimal required scopes per provider
#
# Default scopes by provider:
# - GitHub: "read:user user:email"
# - Google: "openid email profile"
# - Discord: "identify email"
# - Twitter: "users.read tweet.read"

# GitHub OAuth Scopes
# Available scopes: https://docs.github.com/en/apps/oauth-apps/building-oauth-apps/scopes-for-oauth-apps
# OAUTH_SCOPES_GITHUB=read:user user:email

# Google OAuth Scopes
# Available scopes: https://developers.google.com/identity/protocols/oauth2/scopes
# OAUTH_SCOPES_GOOGLE=openid email profile

# Discord OAuth Scopes
# Available scopes: https://discord.com/developers/docs/topics/oauth2#shared-resources-oauth2-scopes
# OAUTH_SCOPES_DISCORD=identify email

# Twitter OAuth Scopes
# Available scopes: https://developer.twitter.com/en/docs/authentication/oauth-2-0/authorization-code
# OAUTH_SCOPES_TWITTER=users.read tweet.read

# ==============================================================================
# ADDITIONAL CONFIGURATION (OPTIONAL)
# ==============================================================================

# Node environment
# NODE_ENV=development

# Application port (if applicable)
# PORT=3000

# ==============================================================================
# SECURITY BEST PRACTICES
# ==============================================================================
#
# 1. NEVER commit .env file to version control
#    - Add .env to your .gitignore file
#
# 2. Use different credentials for each environment
#    - Development, staging, and production should have separate projects
#
# 3. Rotate keys regularly
#    - Generate new keys periodically for enhanced security
#
# 4. Restrict redirect hosts
#    - Only add trusted domains to ALLOWED_REDIRECT_HOSTS
#    - Be cautious with wildcard patterns
#
# 5. Minimize OAuth scopes
#    - Only request permissions your application actually needs
#    - Follow principle of least privilege
#
# 6. Use environment-specific configurations
#    - Consider using .env.development, .env.production, etc.
#
# ==============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==============================================================================
#
# [ ] Replace all example values with actual credentials
# [ ] Configure ALLOWED_REDIRECT_HOSTS for your production domains
# [ ] Set appropriate OAuth scopes for each provider you use
# [ ] Enable Row Level Security (RLS) in Supabase Dashboard
# [ ] Configure email templates in Supabase Dashboard
# [ ] Set up custom SMTP (optional but recommended)
# [ ] Enable MFA for your Supabase account
# [ ] Configure rate limiting if needed
# [ ] Set up monitoring and logging
# [ ] Test authentication flow thoroughly
#
# ==============================================================================
